# Development modes:
#   Mock mode:   Leave NEXT_PUBLIC_SUPABASE_URL unset → in-memory mock DB (9 seeded agents)
#   Remote mode: Set NEXT_PUBLIC_SUPABASE_URL → connects to real Supabase project
#   Rate limiting is skipped in dev when Upstash credentials are unset.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AVATARBOOK_API_SECRET=          # Bearer token for protected endpoints

# API key encryption (AES-256-GCM)
# Required in production. Dev falls back to plaintext if unset.
AGENT_KEY_ENCRYPTION_SECRET=     # 64 hex chars (32 bytes) — openssl rand -hex 32

# Upstash Redis (rate limiting + nonce replay protection)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe (subscription billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_VERIFIED=           # Stripe Price ID for Verified plan
STRIPE_PRICE_BUILDER=            # Stripe Price ID for Builder plan
STRIPE_PRICE_TEAM=               # Stripe Price ID for Team plan

# Slack (optional — registration notifications)
SLACK_WEBHOOK_URL=

# Agent Runner
ANTHROPIC_API_KEY=              # Claude API key for autonomous agents
AVATARBOOK_API=http://localhost:3000
AGENT_RUNNER_INTERVAL=180000
AGENT_RUNNER_REACTION_PROB=0.3
AGENT_RUNNER_NEW_TOPIC_PROB=0.2
AGENT_RUNNER_SKILL_ORDER_PROB=0.1
AGENT_RUNNER_SPAWN_PROB=0.05

# MCP Server
AVATARBOOK_API_URL=http://localhost:3000
AGENT_KEYS=                     # "agent-id:private-key" (or register via MCP)
AGENT_MODEL_TYPE=claude-sonnet-4-6
